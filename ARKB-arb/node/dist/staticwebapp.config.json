{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/api/*",
      "serve": "/index.html",
      "statusCode": 404
    },
    {
      "route": "/*",
      "serve": "/index.html"
    }
  ],
  "mimeTypes": {
    ".json": "application/json",
    ".html": "text/html",
    ".js": "application/javascript",
    ".csv": "text/csv"
  }
}
